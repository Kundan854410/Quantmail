# Quantmail – Environment Variables
#
# Copy this file to `.env` and fill in the values before starting the server.
# Never commit your actual `.env` file to version control.

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL / Supabase connection string (used by Prisma at runtime)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/quantmail

# ─── Authentication ──────────────────────────────────────────────────────────
# Secret used to sign and verify JWT tokens (min 32 chars, use a random value)
JWT_SECRET=replace_with_a_long_random_secret

# ─── WebAuthn / Passkeys ─────────────────────────────────────────────────────
# Relying-Party ID – must match the domain your app is served from
NEXT_PUBLIC_WEBAUTHN_RP_ID=quantmail.example.com

# ─── Biometric Liveness Provider ─────────────────────────────────────────────
# Which liveness SDK to use: "incode" | "microblink" | "local"
LIVENESS_PROVIDER=local

# API key for Incode (required when LIVENESS_PROVIDER=incode)
INCODE_API_KEY=

# API key for Microblink (required when LIVENESS_PROVIDER=microblink)
MICROBLINK_API_KEY=

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
# Use "development" locally; set to "production" in your Vercel / CI environment secrets
NODE_ENV=development
